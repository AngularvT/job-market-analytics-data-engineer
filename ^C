import os
import pandas as pd
from sqlalchemy import create_engine, text


# =========================
# File paths
# =========================
CLEAN_JOBS_PATH = "data/processed/clean_jobs.csv"
JOB_SKILLS_PATH = "data/processed/job_skills.csv"


# =========================
# PostgreSQL connection
# =========================
# Format:
# postgresql+psycopg2://username:password@host:port/database_name
#
# On many local Mac PostgreSQL setups, username is your Mac username
# and password may be empty.
#
# If your PostgreSQL does not require a password, this usually works:
# postgresql+psycopg2://localhost/job_market_db
#
# But SQLAlchemy usually works more reliably with username:
# postgresql+psycopg2://zhaolanboer@localhost:5432/job_market_db

DATABASE_URL = os.getenv(
    "DATABASE_URL",
    "postgresql+psycopg2://zhaolanboer@localhost:5432/job_market_db"
)


def check_file_exists(file_path: str) -> None:
    """
    Check whether the required CSV file exists.
    """
    if not os.path.exists(file_path):
        raise FileNotFoundError(
            f"File not found: {file_path}\n"
            "Please run src/transform.py first to generate processed CSV files."
        )


def load_csv_files():
    """
    Load processed CSV files into pandas DataFrames.
    """
    check_file_exists(CLEAN_JOBS_PATH)
    check_file_exists(JOB_SKILLS_PATH)

    clean_jobs = pd.read_csv(CLEAN_JOBS_PATH)
    job_skills = pd.read_csv(JOB_SKILLS_PATH)

    return clean_jobs, job_skills


def clean_for_database(clean_jobs: pd.DataFrame, job_skills: pd.DataFrame):
    """
    Make final adjustments before loading data into PostgreSQL.
    """
    clean_jobs = clean_jobs.copy()
    job_skills = job_skills.copy()

    # Ensure correct data types.
    clean_jobs["job_id"] = clean_jobs["job_id"].astype(int)
    clean_jobs["salary_min"] = clean_jobs["salary_min"].astype("Int64")
    clean_jobs["salary_max"] = clean_jobs["salary_max"].astype("Int64")
    clean_jobs["salary_avg"] = clean_jobs["salary_avg"].astype(float)
    clean_jobs["rating"] = clean_jobs["rating"].astype(float)
    clean_jobs["num_skills"] = clean_jobs["num_skills"].astype(int)
    clean_jobs["easy_apply_bool"] = clean_jobs["easy_apply_bool"].astype(bool)

    job_skills["job_id"] = job_skills["job_id"].astype(int)
    job_skills["skill"] = job_skills["skill"].astype(str)

    return clean_jobs, job_skills


def create_database_engine():
    """
    Create a SQLAlchemy database engine.
    """
    engine = create_engine(DATABASE_URL)
    return engine


def clear_existing_data(engine) -> None:
    """
    Clear existing data before loading fresh data.
    This keeps the load step repeatable.
    """
    with engine.begin() as conn:
        conn.execute(text("DELETE FROM job_skills;"))
        conn.execute(text("DELETE FROM clean_jobs;"))


def load_data_to_postgres(
    clean_jobs: pd.DataFrame,
    job_skills: pd.DataFrame,
    engine
) -> None:
    """
    Load cleaned DataFrames into PostgreSQL tables.
    """
    # Load clean_jobs first because job_skills has a foreign key to clean_jobs.
    clean_jobs.to_sql(
        "clean_jobs",
        engine,
        if_exists="append",
        index=False
    )

    job_skills.to_sql(
        "job_skills",
        engine,
        if_exists="append",
        index=False
    )


def validate_load(engine) -> None:
    """
    Validate row counts after loading data into PostgreSQL.
    """
    with engine.connect() as conn:
        clean_jobs_count = conn.execute(
            text("SELECT COUNT(*) FROM clean_jobs;")
        ).scalar()

        job_skills_count = conn.execute(
            text("SELECT COUNT(*) FROM job_skills;")
        ).scalar()

        top_skills = conn.execute(
            text("""
                SELECT skill, COUNT(*) AS job_count
                FROM job_skills
                GROUP BY skill
                ORDER BY job_count DESC
                LIMIT 10;
            """)
        ).fetchall()

    print("\n========== LOAD VALIDATION ==========")
    print(f"Rows loaded into clean_jobs: {clean_jobs_count}")
    print(f"Rows loaded into job_skills: {job_skills_count}")

    print("\nTop 10 skills from PostgreSQL:")
    for skill, count in top_skills:
        print(f"- {skill}: {count}")


def main():
    print("Starting load process...")

    clean_jobs, job_skills = load_csv_files()

    print(f"Loaded CSV files.")
    print(f"- clean_jobs rows: {len(clean_jobs)}")
    print(f"- job_skills rows: {len(job_skills)}")

    clean_jobs, job_skills = clean_for_database(clean_jobs, job_skills)

    engine = create_database_engine()

    print("Connected to PostgreSQL.")

    clear_existing_data(engine)

    print("Existing table data cleared.")

    load_data_to_postgres(clean_jobs, job_skills, engine)

    print("Data loaded into PostgreSQL successfully.")

    validate_load(engine)

    print("\nLoad process completed successfully.")


if __name__ == "__main__":
    main()

